<header class="bg-red-500 text-white p-4 shadow-md">
  <nav class="container mx-auto flex justify-between items-center">
    <!-- Logo -->
    <a href="/" class="text-xl font-bold">Airbnb</a>

    <!-- Mobile Hamburger Button -->
    <button id="menu-toggle" class="md:hidden block focus:outline-none">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
      </svg>
    </button>

    <!-- Navigation Links -->
    <ul id="menu" class="hidden md:flex flex-col md:flex-row md:space-x-4 absolute md:static top-16 left-0 w-full bg-red-500 md:w-auto p-4 md:p-0 z-10">
      <% const links = [
        { href: '/', label: 'Airbnb', page: 'index' },
        { href: '/homes', label: 'Homes-List', page: 'Home' },
        { href: '/host/add-home', label: 'Add Home', page: 'addHome' },
        { href: '/favourites', label: 'Favourites', page: 'favourites' },
        { href: '/bookings', label: 'Bookings', page: 'bookings' },
        { href: '/host/host-home-list', label: 'Host Homes', page: 'host-homes' }
      ]; %>
      
      <% links.forEach(link => { %>
        <li>
          <a href="<%= link.href %>" 
             class="<%= currentPage === link.page ? 'bg-red-400' : 'hover:bg-red-400' %> block py-2 px-4 rounded transition duration-300">
             <%= link.label %>
          </a>
        </li>
      <% }); %>
    </ul>
  </nav>
</header>

<script>
  // Toggle mobile menu
  document.getElementById('menu-toggle').addEventListener('click', function() {
    const menu = document.getElementById('menu');
    menu.classList.toggle('hidden');
  });
</script>